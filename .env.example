# Copy to `.env` in this folder (next to docker-compose.yml).
#
# Telegram bot — required to run the bot (`docker compose up` includes bot, or `uv run python -m tg_bot.main` from `bot/`):
# 1. Open Telegram, chat with @BotFather → /newbot → copy the HTTP API token.
# 2. Put it on the line below (replace the placeholder).
TELEGRAM_BOT_TOKEN=

# pgAdmin (docker compose service `pgadmin` → http://localhost:5050)
# Register server: Host db, Port 5432, User postgres, Password postgres (see compose `db` service).
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin

# Backend / Docker API
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/sethack
API_SECRET=dev-secret-change-me
# Key for calling an external LMS backend (leave empty if unused)
LMS_BACKEND_API_KEY=
# Ollama: local daemon vs Ollama.com cloud (native /api/chat — see https://docs.ollama.com/cloud)
OLLAMA_MODE=local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Cloud: create key at https://ollama.com/settings/keys — use a cloud-capable model (e.g. gpt-oss:120b)
OLLAMA_API_KEY=
# Example cloud:
# OLLAMA_MODE=cloud
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=your-ollama-com-api-key
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bot → API (local dev on host; in Docker compose this is overridden to http://api:8000)
API_BASE_URL=http://127.0.0.1:8000

# Web — must match API_SECRET for Docker `web` image (X-API-Key in browser); rebuild web after changes
VITE_API_SECRET=dev-secret-change-me
# Docker `web` (Caddy) only: HTTP basic auth for /admin (user `admin`). Leave empty to disable.
WEB_ADMIN_PASSWORD=
# Public base URL of the web UI (no trailing slash). Used for Telegram menu “Web app” and ?key= links.
# Docker Compose sets the bot to http://localhost:5173 by default (same as published `web` port).
# Production example: https://learnix.mikyss.ru — add the same origin to CORS_ORIGINS for the API.
WEB_PUBLIC_BASE_URL=
# Bot → Telegram Bot API (optional tuning if you see request timeouts on deploy)
TELEGRAM_HTTP_TIMEOUT=120
# e.g. socks5://user:pass@host:1080 — only if api.telegram.org must go through a proxy
TELEGRAM_HTTP_PROXY=
# Browser magic-link session length (days); backend default 3.
WEB_SESSION_TTL_DAYS=3

# Tests
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/sethack_test
